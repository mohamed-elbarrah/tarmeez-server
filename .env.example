# ─────────────────────────────────────────────────────────────
# Server environment variables
# Copy to .env for local development.
# In Docker, DATABASE_URL and ANALYTICS_DATABASE_URL are
# automatically overridden by docker-compose environment: block.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Local dev → localhost
# Docker    → overridden by docker-compose to postgres_main:5432
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/platform_db"

# ── Analytics Database (TimescaleDB) ─────────────────────────
# Local dev → localhost:5433
# Docker    → overridden by docker-compose to postgres_analytics:5432
ANALYTICS_DATABASE_URL="postgresql://postgres:your_password@localhost:5433/analytics_db"

# ── JWT Secrets ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_hex_string
JWT_REFRESH_SECRET=replace_with_64_char_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (BullMQ) ───────────────────────────────────────────
# Local dev → localhost
# Docker    → overridden by docker-compose to redis:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── CORS ──────────────────────────────────────────────────────
# Local dev  → http://localhost:3000
# Production → https://yourdomain.com
CLIENT_URL=http://localhost:3000

# ── Cloudflare R2 ─────────────────────────────────────────────
# Set bucket configurations and credentials for image uploads
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-xxxxxx.r2.dev
