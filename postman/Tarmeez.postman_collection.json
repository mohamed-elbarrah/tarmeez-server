{
  "info": {
    "name": "Tarmeez API (local)",
    "_postman_id": "tarmeez-local-collection",
    "description": "Basic Postman collection for local testing of Tarmeez server endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Root - GET /api",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/"
        }
      }
    },
    {
      "name": "Platform - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"John Merchant\",\n  \"email\": \"merchant@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"1234567890\",\n  \"storeName\": \"My Store\",\n  \"category\": \"general\",\n  \"country\": \"USA\",\n  \"city\": \"NY\",\n  \"description\": \"optional\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/auth/platform/register"
        }
      }
    },
    {
      "name": "Platform - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"merchant@example.com\",\n  \"password\": \"password123\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{base_url}}/api/auth/platform/login" }
      }
    },
    {
      "name": "Customer - Register",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Jane Customer\",\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"1234567890\",\n  \"storeSlug\": \"my-store\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{base_url}}/api/auth/customer/register" }
      }
    },
    {
      "name": "Customer - Login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\",\n  \"storeSlug\": \"my-store\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{base_url}}/api/auth/customer/login" }
      }
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [],
        "url": { "raw": "{{base_url}}/api/auth/refresh" }
      }
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "POST",
        "header": [],
        "url": { "raw": "{{base_url}}/api/auth/logout" }
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/api/auth/me" }
      }
    }
  ]
}
