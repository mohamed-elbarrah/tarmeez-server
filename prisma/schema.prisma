generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  MERCHANT
  CUSTOMER
}

enum MerchantStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ActivityType {
  RETAIL
  CHARITY
}

enum CustomerStatus {
  ACTIVE
  BANNED
}

enum PageType {
  LANDING
  CUSTOM
  POLICY
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  FREE_PRODUCT
  PRODUCT_DISCOUNT
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  DEPLETED
}

// ─── Team Management ─────────────────────────────────────────────────────────

enum StoreRole {
  OWNER
  ADMIN
  EDITOR
  MARKETER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  email        String
  password     String
  name         String?
  role         UserRole @default(CUSTOMER)
  refreshToken String?
  storeId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  merchant  Merchant?
  customers Customer[]
  store     Store?     @relation(fields: [storeId], references: [id])
  storeMembers StoreMember[]

  @@unique([email, storeId])
}

model Merchant {
  id          String         @id @default(uuid())
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id])
  fullName    String
  phone       String
  storeName   String         @unique
  storeSlug   String         @unique
  category    String
  country     String
  city        String
  description String?
  status      MerchantStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  store Store?
}

// ─── Theme System ────────────────────────────────────────────────────────────
model Theme {
  id            String   @id @default(uuid())
  slug          String   @unique   // e.g. 'default', 'charity'
  name          String
  description   String?
  previewImage  String?
  defaultConfig Json     @default("{}") // ThemeConfig JSON (colors, fonts, etc.)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stores        Store[]
}
// ─────────────────────────────────────────────────────────────────────────────

model Store {
  id             String   @id @default(uuid())
  merchantId     String   @unique
  merchant       Merchant @relation(fields: [merchantId], references: [id])
  slug           String   @unique
  name           String
  customDomain   String?  @unique
  domainStatus   String?
  themeId        String?
  theme          Theme?   @relation(fields: [themeId], references: [id])
  isOnboarded    Boolean  @default(false)
  logo           String?
  logoWidth      Int?
  logoHeight     Int?
  showStoreName  Boolean  @default(true)
  favicon        String?
  storeName      String?
  textColor      String?
  headingColor   String?
  buttonColor    String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  fontFamily     String?
  borderRadius   String?
  activityType  ActivityType @default(RETAIL)
  enabledPaymentMethods String[] @default(["cash_on_delivery"])
  
  // Store Settings MVP
  supportEmail   String?
  supportWhatsapp String?
  socialLinks    Json?      @default("[]")
  systemCurrency String     @default("SAR")
  currencyIcon   String?
  taxNumber      String?
  taxPercentage  Float      @default(15.0)
  isTaxEnabled   Boolean    @default(false)

  // Checkout Configuration
  checkoutFieldsConfig Json? @default("[]")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customers  Customer[]
  users      User[]
  products   Product[]
  orders     Order[]
  reviews    Review[]
  wishlists  Wishlist[]
  categories Category[]
  pages      Page[]
  coupons    Coupon[]
  members    StoreMember[]
  invitations StoreInvitation[]
  landingPageGenerations LandingPageGeneration[]
}

model Order {
  id              String      @id @default(uuid())
  orderCode       String      @unique
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id])

  // Customer link (nullable = guest)
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])

  // Customer snapshot
  customerName    String
  customerEmail   String?
  customerPhone   String

  // Shipping address (snapshot)
  shippingCity    String?
  shippingRegion  String?
  shippingStreet  String?
  shippingBuilding String?

  // Custom merchant-defined fields captured at order time
  customFields    Json?

  paymentMethod   String
  paymentStatus   PaymentStatus @default(PENDING)
  transactionId   String?

  subtotal        Decimal
  shippingCost    Decimal     @default(0)
  total           Decimal
  notes           String?
  status          OrderStatus @default(PENDING)

  couponCode      String?
  couponDiscount  Float?      @default(0)
  couponUsage     CouponUsage?

  isAnonymous     Boolean     @default(false)

  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id])
  productId   String
  productName String
  productImage String?
  price       Decimal
  quantity    Int
  total       Decimal
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Category {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  slug      String
  image     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]

  @@unique([storeId, slug])
}

model Product {
  id           String        @id @default(uuid())
  storeId      String
  store        Store         @relation(fields: [storeId], references: [id])
  name         String
  description  String?
  price        Float
  comparePrice Float?
  cost         Float?
  sku          String?
  barcode      String?
  quantity     Int           @default(0)
  trackStock   Boolean       @default(true)
  weight       Float?
  isPhysical   Boolean       @default(true)
  category     String?
  categoryId   String?
  categoryRef  Category?     @relation(fields: [categoryId], references: [id])
  tags         String[]
  images       String[]
  slug         String
  status       ProductStatus @default(DRAFT)
  seoTitle     String?
  seoDesc      String?
  donationMetadata Json?     // { isDonation, targetAmount, currentAmount, donationOptions, allowCustomAmount, progressMessages }
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  reviews      Review[]
  offers       ProductOffer[]
  wishlists    Wishlist[]
  options      ProductOption[]
  variants     ProductVariant[]
  pages        Page[]
  freeCoupons  Coupon[]      @relation("FreeCouponProduct")

  @@unique([storeId, slug])
}

model Page {
  id              String      @id @default(uuid())
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id])
  title           String
  slug            String
  type            PageType
  status          PageStatus  @default(DRAFT)
  content         Json        @default("{}")
  chatHistory     Json?       // Persistent AI conversation: [{role, content}]
  metadata        Json?       // AI page metadata: {prompt, language, tone, generationId}
  showHeader      Boolean     @default(false)
  showFooter      Boolean     @default(false)
  linkedProductId String?
  linkedProduct   Product?    @relation(fields: [linkedProductId], references: [id])
  seoTitle        String?
  seoDescription  String?
  version         Int         @default(1)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([storeId, slug])
}

model Customer {
  id        String         @id @default(uuid())
  storeId   String
  store     Store          @relation(fields: [storeId], references: [id])
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  fullName  String
  phone     String?
  status    CustomerStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  addresses     Address[]
  paymentMethods PaymentMethod[]
  orders        Order[]
  reviews       Review[]
  wishlists     Wishlist[]

  @@unique([storeId, userId])
}

model Address {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  fullName   String
  phone      String
  city       String
  region     String
  street     String
  buildingNo String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model PaymentMethod {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  type         String
  last4        String
  expiryMonth  Int
  expiryYear   Int
  holderName   String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Review {
  id          String   @id @default(uuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([customerId, productId])
}

model ProductOffer {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  title       String
  description String?
  quantity    Int
  price       Decimal
  badge       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Wishlist {
  id          String   @id @default(uuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([customerId, productId])
}

model ProductOption {
  id        String               @id @default(uuid())
  productId String
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  type      String               @default("DROPDOWN")
  position  Int                  @default(0)
  values    ProductOptionValue[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model ProductOptionValue {
  id            String                @id @default(uuid())
  optionId      String
  option        ProductOption         @relation(fields: [optionId], references: [id], onDelete: Cascade)
  value         String
  colorCode     String?
  position      Int                   @default(0)
  variantValues ProductVariantValue[]
}

model ProductVariant {
  id           String                @id @default(uuid())
  productId    String
  product      Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku          String?
  price        Float?
  comparePrice Float?
  quantity     Int                   @default(0)
  image        String?
  isActive     Boolean               @default(true)
  optionValues ProductVariantValue[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model ProductVariantValue {
  id            String             @id @default(uuid())
  variantId     String
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValueId String
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
}

model Coupon {
  id          String       @id @default(uuid())
  storeId     String
  code        String
  name        String
  description String?
  type        CouponType
  status      CouponStatus @default(ACTIVE)

  discountValue    Float?
  maxDiscountAmount Float?

  freeProductId    String?
  freeProductQty   Int?     @default(1)

  applicableProductIds String[] @default([])
  applicableCategoryIds String[] @default([])

  minOrderAmount   Float?
  maxUsageCount    Int?
  usageCount       Int      @default(0)
  perCustomerLimit Int?     @default(1)
  customerIds      String[] @default([])

  startsAt   DateTime?
  expiresAt  DateTime?

  isAutoGenerated Boolean @default(false)

  store    Store         @relation(fields: [storeId], references: [id])
  usages   CouponUsage[]
  freeProduct Product?  @relation("FreeCouponProduct", fields: [freeProductId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, code])
  @@index([storeId, status])
  @@map("coupons")
}

model CouponUsage {
  id         String   @id @default(uuid())
  couponId   String
  orderId    String   @unique
  customerId String?
  discountAmount Float
  usedAt     DateTime @default(now())

  coupon  Coupon @relation(fields: [couponId], references: [id])
  order   Order  @relation(fields: [orderId], references: [id])

  @@index([couponId])
  @@index([customerId, couponId])
  @@map("coupon_usages")
}

// ─── Team Management Models ───────────────────────────────────────────────────

model StoreMember {
  id        String    @id @default(uuid())
  userId    String
  storeId   String
  role      StoreRole @default(EDITOR)
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId])
  @@map("store_members")
}

model StoreInvitation {
  id        String           @id @default(uuid())
  email     String
  storeId   String
  role      StoreRole        @default(EDITOR)
  token     String           @unique
  expiresAt DateTime
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([token])
  @@map("store_invitations")
}

// ─── AI Landing Page Generator ───────────────────────────────

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model LandingPageGeneration {
  id            String           @id @default(uuid())
  storeId       String
  store         Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId     String?
  status        GenerationStatus @default(PENDING)
  prompt        String
  language      String           @default("ar")
  tone          String           @default("professional")
  content       Json?            // Validated AI output (LandingPageContent)
  errorMessage  String?
  pageId        String?          @unique // Links to created Page when completed
  retryCount    Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([storeId])
  @@index([status])
  @@map("landing_page_generations")
}
