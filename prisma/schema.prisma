generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  MERCHANT
  CUSTOMER
}

enum MerchantStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  role         UserRole  @default(CUSTOMER)
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  merchant     Merchant?
  customers    Customer[]
}

model Merchant {
  id          String         @id @default(uuid())
  userId      String         @unique
  user        User           @relation(fields: [userId], references: [id])
  fullName    String
  phone       String
  storeName   String         @unique
  storeSlug   String         @unique
  category    String
  country     String
  city        String
  description String?
  status      MerchantStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  store       Store?
}

model Store {
  id             String    @id @default(uuid())
  merchantId     String    @unique
  merchant       Merchant  @relation(fields: [merchantId], references: [id])
  slug           String    @unique
  name           String
  customDomain   String?   @unique
  domainStatus   String?
  themeId        String?
  isOnboarded    Boolean   @default(false)
  logo           String?
  logoWidth      Int?
  logoHeight     Int?
  showStoreName  Boolean   @default(true)
  favicon        String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  fontFamily     String?
  borderRadius   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customers Customer[]
  products  Product[]
}

model Product {
  id           String        @id @default(uuid())
  storeId      String
  store        Store         @relation(fields: [storeId], references: [id])
  name         String
  description  String?
  price        Float
  comparePrice Float?
  cost         Float?
  sku          String?
  barcode      String?
  quantity     Int           @default(0)
  trackStock   Boolean       @default(true)
  weight       Float?
  isPhysical   Boolean       @default(true)
  category     String?
  tags         String[]
  images       String[]
  slug         String
  status       ProductStatus @default(DRAFT)
  seoTitle     String?
  seoDesc      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([storeId, slug])
}

model Customer {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  fullName  String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, userId])
}
